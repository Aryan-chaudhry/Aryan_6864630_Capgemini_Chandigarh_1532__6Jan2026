@model EcommerceApp.Models.Order

<h2 class="text-center">Place Order</h2>

<div class="d-flex justify-content-center align-content-center m-4">
    <div class="card border-0 shadow p-4 rounded-4 w-50">
        <form asp-action="Create" method="post">
            <div class="mb-3">
                <label class="form-label">Customer</label>
                <select asp-for="CustomerId" asp-items="ViewBag.Customers" class="form-control"></select>
            </div>

            <div class="mb-3">
                <label class="form-label">Product</label>
                <select name="productId" asp-items="ViewBag.Products" class="form-control"></select>
            </div>

            <div class="mb-3">
                <label>Quantity</label>
                <input type="number" name="quantity" class="form-control" />
            </div>

            <div class="mb-2">
                <label class="form-label">Address</label>
                <input type="text" name="address" class="form-control" />
            </div>

            <div class="d-flex justify-content-center align-content-center mt-3">
                <button type="submit" class="btn btn-dark">Place Order</button>
            </div>
        </form>
    </div>
</div>