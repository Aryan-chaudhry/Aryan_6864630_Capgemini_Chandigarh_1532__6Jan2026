@model IEnumerable<EcommerceApp.Models.Customer>

<h2 class="text-center">Customers</h2>

<a asp-action="Create" class="btn btn-dark mb-2">Add Customer</a>

<table class="table">
    <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Action</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Email</td>
            <td>
                <a asp-action="Delete" asp-route-id="@item.CustomerId" class="btn btn-danger btn-sm">Delete</a>
            </td>
        </tr>
    }
</table>