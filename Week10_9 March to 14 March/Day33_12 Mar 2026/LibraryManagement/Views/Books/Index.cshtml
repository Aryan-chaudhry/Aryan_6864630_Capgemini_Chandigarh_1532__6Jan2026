@model List<LibraryManagement.Models.Book>

<h2>Books List</h2>

<table border="1">

    <tr>
        <th>ID</th>
        <th>Title</th>
        <th>Author</th>
        <th>Price</th>
        <th>Action</th>
    </tr>

    @foreach (var book in Model)
    {
        <tr>
            <td>@book.Id</td>
            <td>@book.Title</td>
            <td>@book.Author</td>
            <td>@book.Price</td>
            <td>
                <a href="/Books/Details/@book.Id">Details</a>
            </td>
        </tr>
    }

</table>