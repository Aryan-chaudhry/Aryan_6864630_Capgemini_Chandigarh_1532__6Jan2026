@model List<StudentPortal.Models.Student>

<h2>Students</h2>

<table border="1">
    <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Email</th>
    </tr>

    @foreach (var student in Model)
    {
        <tr>
            <td>@student.Id</td>
            <td>@student.Name</td>
            <td>@student.Email</td>
        </tr>
    }

</table>

<h2>Request Logs</h2>

<table border="1">

    <tr>
        <th>URL</th>
        <th>Execution Time (ms)</th>
        <th>Time</th>
    </tr>

    @foreach (var log in ViewBag.Logs)
    {
        <tr>
            <td>@log.Url</td>
            <td>@log.ExecutionTime</td>
            <td>@log.RequestTime</td>
        </tr>
    }

</table>