<!DOCTYPE html>
<html>
<head>
    <title>Products</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light">

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary px-4">
        <span class="navbar-brand">🛒 ECommerce</span>

        <div class="ms-auto">
            <a class="nav-link d-inline text-white" href="/Order/Index">Orders</a>
            <a class="nav-link d-inline text-white" href="/Product/Index">Products</a>
            <a class="nav-link d-inline text-white" href="/Auth/Logout">Logout</a>
        </div>
    </nav>

    <!-- Content -->
    <div class="container mt-5">

        <h2 class="mb-4">Products</h2>

        <div class="card shadow-sm border-0">
            <div class="card-body">
                <p class="mb-0">@ViewBag.Products</p>
            </div>
        </div>

    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>