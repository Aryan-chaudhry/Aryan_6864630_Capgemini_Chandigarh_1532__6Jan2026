@model OnlineLearningPlatform.Web.ViewModels.CourseViewModel

@{
    ViewData["Title"] = "Edit Course";
}

<div class="container d-flex justify-content-center mt-5">
    <div class="card shadow border-0 rounded-4 p-4" style="width: 600px;">

        <h2 class="text-center mb-4">Edit Course</h2>

        <form method="post">
            <input type="hidden" name="Id" value="@Model.Id" />

            <div class="mb-3">
                <label class="form-label">Title</label>
                <input
                    name="Title"
                    class="form-control"
                    value="@Model.Title"
                    required />
            </div>

            <div class="mb-3">
                <label class="form-label">Description</label>
                <textarea
                    name="Description"
                    class="form-control"
                    rows="5"
                    required>@Model.Description</textarea>
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-primary w-100" type="submit">
                    Save Changes
                </button>

                <a asp-action="Index" class="btn btn-secondary w-100">
                    Cancel
                </a>
            </div>
        </form>

    </div>
</div>