@model OnlineLearningPlatform.Web.ViewModels.CourseViewModel

<div class="container mt-4">

    <!-- Course Header Card -->
    <div class="card shadow border-0 rounded-4 p-4 mb-4">
        <div class="d-flex justify-content-between align-items-center">
            <h2 class="mb-0">@Model.Title</h2>
            <div>
                <a asp-action="Index" class="btn btn-secondary">Back to Courses</a>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit Course</a>
            </div>
        </div>

        <hr />

        <p class="mb-0">@Model.Description</p>
    </div>

    <!-- Lessons Card -->
    <div class="card shadow border-0 rounded-4 p-4 mb-4">
        <h4 class="mb-3">Lessons</h4>

        <ul class="list-group">
            @foreach (var lesson in (List<OnlineLearningPlatform.Web.ViewModels.LessonViewModel>)ViewBag.Lessons)
            {
                <li class="list-group-item mb-2 rounded-3">
                    <strong>@lesson.Title</strong>
                    <br />
                    <span>@lesson.Content</span>
                </li>
            }
        </ul>
    </div>

    <!-- Add Lesson Card -->
    <div class="card shadow border-0 rounded-4 p-4">
        <h4 class="mb-3">Add Lesson</h4>

        <form method="post" asp-action="AddLesson">
            <input type="hidden" name="courseId" value="@Model.Id" />

            <div class="mb-3">
                <label class="form-label">Lesson Title</label>
                <input name="title" class="form-control" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Lesson Content</label>
                <textarea name="content" class="form-control" rows="4" required></textarea>
            </div>

            <button type="submit" class="btn btn-success w-100">
                Add Lesson
            </button>
        </form>
    </div>

</div>