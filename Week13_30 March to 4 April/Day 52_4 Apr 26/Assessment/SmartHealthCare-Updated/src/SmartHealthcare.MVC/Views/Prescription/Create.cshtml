@model SmartHealthcare.Models.DTOs.CreatePrescriptionDTO
@{
    ViewData["Title"] = "Create Prescription";
    var appointment = ViewBag.Appointment as SmartHealthcare.Models.DTOs.AppointmentDTO;
}

<div class="container-fluid mt-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0">Create Prescription</h4>
            <small class="text-muted">Add diagnosis and medicines</small>
        </div>

        <a href="@Url.Action("Details", "Appointment", new { id = Model.AppointmentId })"
           class="btn btn-outline-dark btn-sm">
            Back
        </a>
    </div>

    <!-- Appointment Info -->
    @if (appointment != null)
    {
        <div class="alert alert-light border mb-3">
            <strong>Appointment:</strong>
            #@appointment.Id —
            @appointment.PatientName with Dr. @appointment.DoctorName
        </div>
    }

    <!-- FORM CARD -->
    <div class="card border-0 shadow-sm">

        <div class="card-body">

            <form asp-action="Create" method="post">

                <input type="hidden" asp-for="AppointmentId" />

                <!-- Diagnosis -->
                <div class="mb-3">
                    <label asp-for="Diagnosis" class="form-label">
                        Diagnosis <span class="text-danger">*</span>
                    </label>
                    <textarea asp-for="Diagnosis"
                              class="form-control"
                              rows="3"
                              placeholder="Enter diagnosis details"></textarea>
                    <span asp-validation-for="Diagnosis" class="text-danger"></span>
                </div>

                <!-- Notes -->
                <div class="mb-3">
                    <label asp-for="Notes" class="form-label">Additional Notes</label>
                    <textarea asp-for="Notes"
                              class="form-control"
                              rows="2"
                              placeholder="Any additional notes"></textarea>
                </div>

                <hr />

                <!-- Medicines Header -->
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h6 class="mb-0">Medicines</h6>

                    <button type="button"
                            class="btn btn-dark btn-sm"
                            id="add-medicine-btn">
                        + Add Medicine
                    </button>
                </div>

                <!-- Medicines List -->
                <div id="medicines-list"></div>

                <!-- Submit -->
                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-success btn-sm">
                        Create Prescription
                    </button>

                    <a href="@Url.Action("Details", "Appointment", new { id = Model.AppointmentId })"
                       class="btn btn-outline-secondary btn-sm">
                        Cancel
                    </a>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        let medicineIndex = 0;

        function addMedicine() {
            const container = document.getElementById("medicines-list");

            const html = `
                <div class="border rounded p-3 mb-3 bg-light">

                    <div class="d-flex justify-content-between mb-2">
                        <strong>Medicine</strong>
                        <button type="button"
                                class="btn btn-sm btn-outline-danger"
                                onclick="removeMedicine(this)">
                            Remove
                        </button>
                    </div>

                    <div class="row g-2">

                        <div class="col-md-6">
                            <label class="form-label">Name *</label>
                            <input type="text"
                                   name="Medicines[${medicineIndex}].Name"
                                   class="form-control"
                                   required />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Dosage *</label>
                            <input type="text"
                                   name="Medicines[${medicineIndex}].Dosage"
                                   class="form-control"
                                   placeholder="500mg"
                                   required />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Duration *</label>
                            <input type="text"
                                   name="Medicines[${medicineIndex}].Duration"
                                   class="form-control"
                                   placeholder="7 days"
                                   required />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Instructions</label>
                            <input type="text"
                                   name="Medicines[${medicineIndex}].Instructions"
                                   class="form-control"
                                   placeholder="After meals" />
                        </div>

                    </div>
                </div>
            `;

            container.insertAdjacentHTML("beforeend", html);
            medicineIndex++;
        }

        function removeMedicine(btn) {
            btn.closest(".border").remove();
        }

        document.getElementById("add-medicine-btn")
            .addEventListener("click", addMedicine);

        // default medicine
        addMedicine();
    </script>
}