@{
    ViewData["Title"] = "Dashboard";
    var role = ViewBag.Role as string;
    var fullName = ViewBag.FullName as string;
}

<div class="container-fluid mt-4">

    <!-- Header -->
    <div class="mb-4">
        <h3 class="mb-1">Dashboard</h3>
        <p class="text-muted mb-0">
            Welcome, <strong>@fullName</strong> | Role: <strong>@role</strong>
        </p>
    </div>

    @{
        if (role == "Admin")
        {
            <!-- ADMIN -->

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body d-flex gap-2 flex-wrap">
                    <a href="@Url.Action("Users", "Admin")" class="btn btn-dark btn-sm">Manage Users</a>
                    <a href="@Url.Action("Index", "Doctor")" class="btn btn-outline-dark btn-sm">Doctors</a>
                    <a href="@Url.Action("Index", "Appointment")" class="btn btn-outline-dark btn-sm">Appointments</a>
                    <a href="@Url.Action("Reports", "Admin")" class="btn btn-outline-dark btn-sm">Reports</a>
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h6 class="mb-0">Recent Appointments</h6>
                </div>
                <div class="card-body p-0 table-responsive">

                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Patient</th>
                                <th>Doctor</th>
                                <th>Date</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>John Doe</td>
                                <td>Dr. Smith</td>
                                <td>10 Apr 2026</td>
                                <td><span class="badge bg-success">Confirmed</span></td>
                            </tr>
                            <tr>
                                <td>Jane Doe</td>
                                <td>Dr. Kumar</td>
                                <td>11 Apr 2026</td>
                                <td><span class="badge bg-warning text-dark">Pending</span></td>
                            </tr>
                        </tbody>
                    </table>

                </div>
            </div>
        }
        else if (role == "Doctor")
        {
            <!-- DOCTOR -->

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body d-flex gap-2">
                    <a href="@Url.Action("Index", "Appointment")" class="btn btn-dark btn-sm">My Appointments</a>
                    <a href="@Url.Action("Profile", "Patient")" class="btn btn-outline-dark btn-sm">Profile</a>
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h6 class="mb-0">Today’s Schedule</h6>
                </div>
                <div class="card-body p-0 table-responsive">

                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Patient</th>
                                <th>Time</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Rahul Sharma</td>
                                <td>10:30 AM</td>
                                <td><span class="badge bg-success">Confirmed</span></td>
                            </tr>
                            <tr>
                                <td>Amit Verma</td>
                                <td>12:00 PM</td>
                                <td><span class="badge bg-warning text-dark">Pending</span></td>
                            </tr>
                        </tbody>
                    </table>

                </div>
            </div>
        }
        else if (role == "Patient")
        {
            <!-- PATIENT -->

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body d-flex gap-2 flex-wrap">
                    <a href="@Url.Action("Create", "Appointment")" class="btn btn-dark btn-sm">Book Appointment</a>
                    <a href="@Url.Action("Index", "Appointment")" class="btn btn-outline-dark btn-sm">My Appointments</a>
                    <a href="@Url.Action("Profile", "Patient")" class="btn btn-outline-dark btn-sm">Profile</a>
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h6 class="mb-0">My Appointments</h6>
                </div>
                <div class="card-body p-0 table-responsive">

                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Doctor</th>
                                <th>Date</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Dr. Kumar</td>
                                <td>12 Apr 2026</td>
                                <td><span class="badge bg-success">Confirmed</span></td>
                            </tr>
                            <tr>
                                <td>Dr. Singh</td>
                                <td>15 Apr 2026</td>
                                <td><span class="badge bg-danger">Cancelled</span></td>
                            </tr>
                        </tbody>
                    </table>

                </div>
            </div>
        }
    }

</div>