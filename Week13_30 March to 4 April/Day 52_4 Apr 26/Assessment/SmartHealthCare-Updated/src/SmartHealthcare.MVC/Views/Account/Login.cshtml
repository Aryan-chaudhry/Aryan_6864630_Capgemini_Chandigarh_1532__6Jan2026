@model SmartHealthcare.Models.DTOs.LoginDTO
@{
    ViewData["Title"] = "Login";
}

<div class="container-fluid min-vh-100 d-flex justify-content-center align-items-center">
    <div class="col-md-5 col-lg-4">

        <div class="card border-0 shadow rounded-4 p-4">

            <!-- Header -->
            <div class="mb-3 text-center">
                <h4 class="mb-1">Smart Healthcare</h4>
                <p class="mb-0">Login to your account</p>
            </div>

            <!-- Form -->
            <form asp-action="Login" method="post" novalidate>

                <!-- Email -->
                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" placeholder="Enter your email" />
                    <span asp-validation-for="Email"></span>
                </div>

                <!-- Password -->
                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Enter your password" />
                    <span asp-validation-for="Password"></span>
                </div>

                <!-- Remember Me -->
                <div class="mb-3 d-flex align-items-center">
                    <input type="checkbox" id="rememberMe" class="me-2" />
                    <label for="rememberMe" class="mb-0">Remember me</label>
                </div>

                <!-- Button -->
                <div class="d-grid mb-3">
                    <button type="submit" class="btn btn-dark">Login</button>
                </div>
            </form>

            <!-- Footer -->
            <div class="text-center">
                <p class="mb-0">
                    Don't have an account?
                    <a asp-action="Register">Register</a>
                </p>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}