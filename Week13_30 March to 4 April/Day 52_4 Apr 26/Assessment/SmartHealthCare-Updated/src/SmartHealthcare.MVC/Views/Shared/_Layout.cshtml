<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Smart Healthcare</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light">

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg bg-white border-bottom">
        <div class="container">

            <a class="navbar-brand fw-semibold" asp-controller="Home" asp-action="Index">
                Smart Healthcare
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navBar">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navBar">

                <!-- Left -->
                <ul class="navbar-nav me-auto">

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                    </li>

                    @if (Context.Session.GetString("Token") != null)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Appointment" asp-action="Index">Appointments</a>
                        </li>

                        @if (Context.Session.GetString("Role") == "Patient")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Patient" asp-action="Billing">Billing</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Patient" asp-action="MedicalHistory">Prescriptions</a>
                            </li>
                        }

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Patient" asp-action="Profile">Profile</a>
                        </li>
                    }
                </ul>

                <!-- Right -->
                <div class="d-flex align-items-center gap-2">

                    @if (Context.Session.GetString("Token") != null)
                    {
                        <span class="small text-muted">
                            @Context.Session.GetString("FullName")
                        </span>

                        <a class="btn btn-dark btn-sm" asp-controller="Account" asp-action="Logout">
                            Logout
                        </a>
                    }
                    else
                    {
                        <a class="btn btn-outline-dark btn-sm" asp-controller="Account" asp-action="Login">
                            Login
                        </a>

                        <a class="btn btn-dark btn-sm" asp-controller="Account" asp-action="Register">
                            Register
                        </a>
                    }

                </div>
            </div>
        </div>
    </nav>

    <!-- Main -->
    <main class="container py-4">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        @if (TempData["Info"] != null)
        {
            <div class="alert alert-info">@TempData["Info"]</div>
        }

        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="border-top py-3 mt-4 bg-white">
        <div class="container d-flex justify-content-between">
            <span class="small text-muted">© 2026 Smart Healthcare</span>
            <span class="small text-muted">All-in-one healthcare management</span>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>