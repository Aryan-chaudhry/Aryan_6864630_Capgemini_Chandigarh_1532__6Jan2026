@model IEnumerable<SmartHealthcare.Models.DTOs.AppointmentDTO>
@{
    ViewData["Title"] = "My Appointments";
    var role = ViewBag.Role as string;
}

<div class="container-fluid mt-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0">Appointments</h4>
            <small class="text-muted">Manage your appointments</small>
        </div>

        @if (role == "Patient")
        {
            <a asp-action="Create" class="btn btn-dark btn-sm">
                Book Appointment
            </a>
        }
    </div>

    @if (Model.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0 table-responsive">

                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Patient</th>
                            <th>Doctor</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th style="width:180px;">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>#@item.Id</td>
                                <td>@item.PatientName</td>
                                <td>Dr. @item.DoctorName</td>
                                <td>@item.AppointmentDate.ToString("dd MMM yyyy, hh:mm tt")</td>
                                <td>
                                    <span class="badge bg-@GetStatusColor(item.Status)">
                                        @item.Status
                                    </span>
                                </td>
                                <td>
                                    <div class="d-flex gap-1">

                                        <a asp-action="Details" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-dark">
                                            View
                                        </a>

                                        @if (role == "Doctor")
                                        {
                                            <a asp-action="Create"
                                               asp-controller="Prescription"
                                               asp-route-appointmentId="@item.Id"
                                               class="btn btn-sm btn-dark">
                                                Prescription
                                            </a>
                                        }

                                    </div>
                                </td>
                            </tr>

                            @* Optional Notes Row *@
                            @if (!string.IsNullOrEmpty(item.Notes))
                            {
                                <tr class="table-light">
                                    <td></td>
                                    <td colspan="5" class="small text-muted">
                                        <strong>Notes:</strong> @item.Notes
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>

            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm text-center p-4">
            <h6 class="mb-2">No Appointments</h6>
            <p class="text-muted small">You don’t have any appointments yet.</p>

            @if (role == "Patient")
            {
                <a asp-action="Create" class="btn btn-dark btn-sm">
                    Book Appointment
                </a>
            }
        </div>
    }

</div>

@functions {
    private string GetStatusColor(string status)
    {
        return status?.ToLower() switch
        {
            "pending" => "warning",
            "completed" => "success",
            "cancelled" => "danger",
            _ => "secondary"
        };
    }
}