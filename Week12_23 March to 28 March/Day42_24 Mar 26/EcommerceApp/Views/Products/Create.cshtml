@model EcommerceApp.Models.Product

<h2 class="text-center">Add Product</h2>

<div class="d-flex justify-content-center align-content-center m-4">
	<div class="card border-0 shadow p-4 rounded-4">
        <form asp-action="Create" method="post">
            <div class="mb-2">
                <label>Name</label>
                <input asp-for="Name" class="form-control" />
            </div>

            <div class="mb-2">
                <label>Price</label>
                <input asp-for="Price" class="form-control" />
            </div>

            <div class="mb-2">
                <label>Category</label>
                <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-control"></select>
            </div>

            <button type="submit" class="btn btn-success">Save</button>
        </form>
	</div>
</div>