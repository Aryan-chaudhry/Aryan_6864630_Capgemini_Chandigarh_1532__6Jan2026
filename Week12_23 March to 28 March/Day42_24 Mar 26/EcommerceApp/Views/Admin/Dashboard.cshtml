@{
    ViewData["Title"] = "Admin Dashboard";
}

<h2 class="mb-4">Admin Dashboard</h2>


<div class="d-flex justify-content-evenly align-content-center g-4">
    <div class="card m-4 shadow border-0 rounded-4 w-50">
        <div class="card-header bg-dark text-white">
            Top 5 Selling Products
        </div>

        <div class="card-body">
            <table class="table">
                <tr>
                    <th>Product ID</th>
                    <th>Product Name</th>
                    <th>Total Sold</th>
                </tr>

                @foreach (var item in ViewBag.TopProducts)
                {
                    <tr>
                        <td>@item.ProductId</td>
                        <td>@item.ProductName</td>
                        <td>@item.TotalSold</td>
                    </tr>
                }
            </table>
        </div>
    </div>


    <div class="card m-4 shadow border-0 rounded-4 w-50">
        <div class="card-header bg-dark text-white">
            Pending Shipments
        </div>

        <div class="card-body">
            <table class="table">
                <tr>
                    <th>Order ID</th>
                    <th>Customer</th>
                    <th>Status</th>
                </tr>

                @foreach (var item in ViewBag.PendingOrders)
                {
                    <tr>
                        <td>@item.OrderId</td>
                        <td>@item.CustomerName</td>
                        <td>@item.Status</td>
                    </tr>
                }
            </table>
        </div>
    </div>
</div>